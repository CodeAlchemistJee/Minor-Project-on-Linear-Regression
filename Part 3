# 4. ADVANCED: PIECEWISE & KERNEL RIDGE
# ==========================================
print("\n--- ADVANCED FEATURES: SPLINES & KERNELS ---")

def piecewise_linear_regression(X, y, knots):
    """Fits independent linear regressions between given 'knots' (Splines)"""
    preds = np.zeros_like(y)
    bins = np.digitize(X, knots)
    
    for i in range(len(knots) + 1):
        idx = (bins == i)
        if np.sum(idx) > 1: # If enough data exists in this segment
            x_seg = np.c_[np.ones(np.sum(idx)), X[idx]]
            y_seg = y[idx]
            # Normal Equation for local segment
            w_seg = np.linalg.inv(x_seg.T.dot(x_seg) + 0.1*np.eye(2)).dot(x_seg.T).dot(y_seg)
            preds[idx] = x_seg.dot(w_seg)
    return preds

def kernel_ridge_poly(X, y, degree=3, lambda_=1.0):
    """Implements the Kernel Trick for non-linear regression using matrix math"""
    X_mat = X.reshape(-1, 1)
    # Polynomial Kernel K(x, x') = (1 + x^T x')^d
    K = (1 + X_mat.dot(X_mat.T)) ** degree
    
    # alpha = (K + lambda*I)^-1 * y
    alpha = np.linalg.inv(K + lambda_ * np.eye(len(X))).dot(y)
    
    # Predict on self
    return K.dot(alpha)

# Apply Splines
knots = [2000, 4000] # Break the data into 3 segments
spline_preds = piecewise_linear_regression(area, price, knots)

plt.subplot(1, 3, 3)
plt.scatter(area, price, alpha=0.3, color='gray')
plt.plot(area, spline_preds, color='purple', linewidth=3, label='Piecewise Splines')
for k in knots:
    plt.axvline(x=k, color='black', linestyle='--', alpha=0.5)
plt.title("Piecewise Polynomial (Splines)")
plt.xlabel("Area (sq ft)")
plt.legend()

plt.tight_layout()
plt.show()

